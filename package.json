{
  "name": "react-native-sia",
  "version": "0.0.2",
  "description": "The Sia SDK for React Native.",
  "main": "./lib/module/public.js",
  "types": "./lib/typescript/src/public.d.ts",
  "exports": {
    ".": {
      "source": "./src/public.ts",
      "types": "./lib/typescript/src/public.d.ts",
      "default": "./lib/module/public.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "ubrn:ios": "RUSTUP_TOOLCHAIN=nightly ubrn build ios --and-generate && (cd example/ios && pod install)",
    "ubrn:android": "ubrn build android --and-generate",
    "ubrn:web": "ubrn build web",
    "ubrn:checkout": "ubrn checkout",
    "ubrn:clean": "yarn dlx rimraf --glob cpp android/CMakeLists.txt android/src/main/java 'android/*.cpp' ios 'src/Native*' 'src/index.*ts*' src/generated SiaFramework.xcframework",
    "example": "yarn workspace react-native-sia-example",
    "test": "jest",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "version": "changeset version && yarn install",
    "release": "changeset publish"
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "^0.29.3-1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.7",
    "@eslint/compat": "^1.2.7",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@react-native-community/cli": "15.0.0-alpha.2",
    "@react-native/babel-preset": "0.81.0",
    "@react-native/eslint-config": "^0.78.0",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.1.0",
    "del-cli": "^5.1.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-builder-bob": "^0.40.13",
    "turbo": "^1.10.7",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!rust",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "keywords": [
    "sia",
    "sia-sdk",
    "indexd",
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SiaFoundation/react-native-sia.git"
  },
  "author": "The Sia Foundation <hello@sia.tech> (https://github.com/SiaFoundation)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SiaFoundation/react-native-sia/issues"
  },
  "homepage": "https://github.com/SiaFoundation/react-native-sia#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "workspaces": [
    ".",
    "example"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "SiaSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.sia"
    }
  },
  "create-react-native-library": {
    "languages": "kotlin-objc",
    "type": "turbo-module",
    "version": "0.53.0"
  }
}
